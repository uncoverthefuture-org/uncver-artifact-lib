{
  "name": "uncver-knowledge-graph",
  "version": "1.0.0",
  "description": "Knowledge graph manager for artifact metadata, commands, and status. Integrates with uncver-kg for persistent storage.",
  "language": "go",
  "build_type": "go-binary",
  "author": "uncver",
  "repository": "https://github.com/uncoverthefuture-org/uncver-artifact-lib/tree/main/knowledge-graph",
  "entrypoint": "./knowledge-graph",
  "environment": {
    "REDIS_ADDR": "localhost:6379",
    "KG_DATA_PATH": "./data",
    "UNCVERKG_PATH": "uncverkg",
    "COMMAND_STREAM": "uncver:stream:commands",
    "STATS_STREAM": "uncver:stream:stats",
    "RESPONSE_STREAM": "uncver:stream:responses",
    "API_PORT": "8085"
  },
  "required_artifacts": [
    {
      "name": "uncver-redis-stream",
      "required": true,
      "auto_start": true
    }
  ],
  "ports": {
    "api": 8085,
    "metrics": 9095
  },
  "build": {
    "dependencies": ["go", "uncverkg"],
    "steps": [
      "go mod init uncver-knowledge-graph 2>/dev/null || true",
      "go mod tidy",
      "go build -o knowledge-graph cmd/server/main.go"
    ]
  },
  "test": {
    "command": "go test ./..."
  },
  "package": {
    "files": ["knowledge-graph", "kg.json"],
    "docker": false
  },
  "features": [
    "Listens to Redis for artifact stats/commands requests",
    "Stores artifact metadata in uncver-kg knowledge graph",
    "Responds to mercury-inception AI queries about artifacts",
    "Maintains artifact command registry",
    "Tracks artifact health and status",
    "Supports bulk knowledge operations",
    "Query interface for artifact discovery"
  ],
  "commands": {
    "query_artifacts": {
      "description": "Query all artifacts and their status",
      "stream": "uncver:stream:stats",
      "response_type": "artifact_list"
    },
    "query_commands": {
      "description": "Query available commands for an artifact",
      "stream": "uncver:stream:commands",
      "response_type": "command_list"
    },
    "register_artifact": {
      "description": "Register a new artifact in the knowledge graph",
      "stream": "uncver:stream:commands",
      "action": "register"
    },
    "update_status": {
      "description": "Update artifact status",
      "stream": "uncver:stream:stats",
      "action": "update_status"
    }
  },
  "redis_topics": [
    "uncver:kg:query",
    "uncver:kg:commands",
    "uncver:kg:stats",
    "uncver:kg:responses"
  ]
}
