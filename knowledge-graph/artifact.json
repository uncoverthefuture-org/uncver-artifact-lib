{
  "name": "uncver-knowledge-graph",
  "version": "1.0.0",
  "description": "Knowledge graph interface for mercury-inception AI. Stores facts (Subject-Predicate-Object) using uncver-kg and provides query interface.",
  "language": "go",
  "build_type": "go-binary",
  "author": "uncver",
  "repository": "https://github.com/uncoverthefuture-org/uncver-artifact-lib/tree/main/knowledge-graph",
  "entrypoint": "./knowledge-graph",
  "environment": {
    "REDIS_ADDR": "localhost:6379",
    "KG_STREAM": "uncver:stream:knowledge",
    "QUERY_STREAM": "uncver:stream:queries",
    "API_PORT": "8085"
  },
  "required_artifacts": [
    {
      "name": "uncver-redis-stream",
      "required": true,
      "auto_start": true
    }
  ],
  "ports": {
    "api": 8085
  },
  "build": {
    "dependencies": ["go", "uncverkg"],
    "steps": [
      "go mod init uncver-knowledge-graph 2>/dev/null || true",
      "go mod tidy",
      "go build -o knowledge-graph cmd/server/main.go"
    ]
  },
  "package": {
    "files": ["knowledge-graph", "kg.json"],
    "docker": false
  },
  "features": [
    "Stores facts using uncver-kg CLI (Subject-Predicate-Object)",
    "Answers knowledge queries from mercury-inception AI",
    "Listens for knowledge write requests via Redis",
    "Provides query interface for AI context retrieval",
    "Maintains conversation context and learned facts"
  ],
  "uncverkg_commands": {
    "write": "uncverkg write --subject '{}' --predicate '{}' --object '{}'",
    "read": "uncverkg read --query '{}'",
    "bulk": "uncverkg bulk --file '{}'",
    "chat": "uncverkg chat"
  }
}
