{
  "name": "uncver-create",
  "version": "1.0.0",
  "description": "Creates uncver artifacts via Redis streams - clones repositories and generates artifact.json",
  "language": "cpp",
  "build_type": "cmake",
  "author": "uncver",
  "repository": "https://github.com/uncoverthefuture-org/uncver-artifact-lib/tree/main/create",
  "container_image": "ghcr.io/uncver/create:latest",
  "entrypoint": "uncver-create",
  "environment": {
    "REDIS_HOST": "localhost",
    "REDIS_PORT": "6379"
  },
  "required_artifacts": [
    {
      "name": "uncver-redis-stream",
      "required": true
    }
  ],
  "build": {
    "dependencies": ["cmake", "make", "g++"],
    "steps": [
      "mkdir -p build",
      "cd build && cmake ..",
      "cd build && make -j$(nproc)"
    ]
  },
  "test": {
    "command": "cd build && ctest --output-on-failure"
  },
  "package": {
    "files": ["uncver-create"],
    "docker": true
  }
}
