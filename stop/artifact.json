{
  "name": "uncver-stop",
  "version": "1.0.0",
  "description": "Stops uncver artifacts via Redis streams - stops running containers",
  "language": "cpp",
  "build_type": "cmake",
  "author": "uncver",
  "repository": "https://github.com/uncoverthefuture-org/uncver-artifact-lib/tree/main/stop",
  "entrypoint": "uncver-stop",
  "environment": {
    "REDIS_HOST": "localhost",
    "REDIS_PORT": "6379"
  },
  "required_artifacts": [
    {
      "name": "uncver-redis-stream",
      "required": true
    }
  ],
  "build": {
    "dependencies": ["cmake", "make", "g++"],
    "steps": [
      "mkdir -p build",
      "cd build && cmake ..",
      "cd build && make -j$(nproc)"
    ]
  },
  "package": {
    "files": ["uncver-stop"],
    "docker": false
  }
}
